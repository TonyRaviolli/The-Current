# Server
PORT=5173
BASE_URL=http://localhost:5173

# Refresh
REFRESH_DRY_RUN=false
REFRESH_DISABLE_SCHEDULE=false

# Storage
DATA_DIR=./data

# Admin protection for refresh/source/scoring endpoints in production
ADMIN_TOKEN=replace-with-a-long-random-secret

# Logging (optional — omit to log to stdout only)
# LOG_FILE=./data/logs/app.log

# Anthropic Claude API (required for AI-enhanced briefs and topic classification)
ANTHROPIC_API_KEY=sk-ant-...

# Official-source APIs
CONGRESS_API_KEY=
GOVINFO_API_KEY=
API_DATA_GOV_KEY=
